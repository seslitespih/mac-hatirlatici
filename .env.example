# Maç Hatırlatıcı — Environment Variables
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun
# cp .env.example .env

# ─── API Keys ─────────────────────────────────────────────────────────────────

# football-data.org (ücretsiz)
# Kayıt: https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=

# API-Football via RapidAPI (100 istek/gün ücretsiz)
# Kayıt: https://rapidapi.com/api-sports/api/api-football
RAPID_API_KEY=

# ─── Build ────────────────────────────────────────────────────────────────────

# Android keystore bilgileri (build sırasında kullanılır)
KEYSTORE_PASSWORD=
KEY_ALIAS=mac-hatirlatici
KEY_PASSWORD=
